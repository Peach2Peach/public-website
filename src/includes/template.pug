include /mixins.pug

block vars
  //- Derive a unique page title for templated page clusters (programmatic buy
  //- pages, FAQ currency pages, blog tag + index pages) so 480+ pages don't
  //- share identical <title> tags. Falls back to the markdown-extracted title
  //- or the generic brand+tagline pair for plain pages.
  - let derivedTitle = title
  - const _programmaticMatch = permalink && permalink.match(/^buy-bitcoin-with-(.+)$/i)
  - const _faqCurrencyMatch = permalink && permalink.match(/^faq\/Buy-&-Sell-Bitcoin-using-(.+)-in-\d+$/i)
  - const _isBlogIndex = permalink === 'blog'
  - const _isBlogTag = typeof tag === 'string' && tag
  - if (_programmaticMatch) {
  -   const raw = _programmaticMatch[1]
  -   const formatted = raw.split('-').map(w => w === w.toLowerCase() ? (w.charAt(0).toUpperCase() + w.slice(1)) : w).join(' ')
  -   derivedTitle = i18n('seo.title.programmaticBuy', lang, formatted)
  - } else if (_faqCurrencyMatch) {
  -   derivedTitle = i18n('seo.title.faqPaymentMethod', lang, _faqCurrencyMatch[1].toUpperCase())
  - } else if (_isBlogTag) {
  -   const tagLabel = i18n('tag.' + tag, lang)
  -   const displayTag = tagLabel && tagLabel !== ('tag.' + tag) ? tagLabel : tag
  -   derivedTitle = i18n('seo.title.blogTag', lang, displayTag)
  - } else if (_isBlogIndex) {
  -   derivedTitle = i18n('seo.title.blogIndex', lang)
  - }
  //- Homepage + plain-page fallback: brand · localized tagline.
  - const _tagline = i18n('seo.tagline', lang) || siteData.meta.tagline
  - const pageTitle = derivedTitle && derivedTitle !== siteData.meta.title ? `${derivedTitle} · ${siteData.meta.title}` : `${siteData.meta.title} · ${_tagline}`
  //- Derive unique descriptions for the same templated page clusters so
  //- programmatic/FAQ/blog-tag pages stop sharing the siteData.meta fallback.
  - let _derivedDescription = description
  - if (!_derivedDescription) {
  -   if (_programmaticMatch) {
  -     const raw = _programmaticMatch[1]
  -     const formatted = raw.split('-').map(w => w === w.toLowerCase() ? (w.charAt(0).toUpperCase() + w.slice(1)) : w).join(' ')
  -     _derivedDescription = i18n('seo.desc.programmaticBuy', lang, formatted)
  -   } else if (_faqCurrencyMatch) {
  -     _derivedDescription = i18n('seo.desc.faqPaymentMethod', lang, _faqCurrencyMatch[1].toUpperCase())
  -   } else if (_isBlogTag) {
  -     const tagLabel = i18n('tag.' + tag, lang)
  -     const displayTag = tagLabel && tagLabel !== ('tag.' + tag) ? tagLabel : tag
  -     _derivedDescription = i18n('seo.desc.blogTag', lang, displayTag)
  -   } else if (_isBlogIndex) {
  -     _derivedDescription = i18n('seo.desc.blogIndex', lang)
  -   }
  - }
  - const pageDescription = _derivedDescription || siteData.meta.description
  - const twitterDescriptionContent = twitterDescription || siteData.meta.twitterDescription
  - const ogTitleContent = ogTitle || derivedTitle || siteData.meta.ogTitle
  - const ogDescriptionContent = ogDescription || siteData.meta.ogDescription
  - const pageKeywords = keywords || siteData.meta.keywords
  - const pageCard = previewImage || cardImage || teaser || siteData.meta.cardImage
  - const themeColor = siteData.meta.themeColor
  //- SEO: canonical + hreflang helpers.
  //- `permalink` is the language-agnostic slug (e.g. "index", "blog/some-post").
  //- `siteBaseUrl` is the production origin used for absolute URLs in head tags.
  - const siteBaseUrl = 'https://peachbitcoin.com'
  - const pagePath = (!permalink || permalink === 'index') ? '/' : `/${permalink}/`
  - const canonicalUrl = `${siteBaseUrl}${getUrl(pagePath, lang)}`
  //- Emit hreflang only for locales where a translation of this page exists.
  //- `permalinkLocales` is built in tasks/generate_site_data.js.
  - const availableLangs = (siteData.permalinkLocales && siteData.permalinkLocales[permalink]) || [lang]
  //- JSON-LD: Organization + WebSite sitewide; MobileApplication on homepage;
  //- BlogPosting on blog posts. Emitted below as a single @graph script.
  - const _socialLinks = [siteData.meta.twitterUrl, siteData.meta.telegramUrl, siteData.meta.discordUrl, siteData.meta.instagramUrl, siteData.meta.nostrUrl, siteData.meta.youtubeUrl, 'https://github.com/Peach2Peach'].filter(Boolean)
  - const _orgNode = { '@type': 'Organization', '@id': `${siteBaseUrl}/#org`, name: siteData.meta.title, url: siteBaseUrl, logo: `${siteBaseUrl}/img/peach-bitcoin.svg`, sameAs: _socialLinks }
  - const _websiteNode = { '@type': 'WebSite', '@id': `${siteBaseUrl}/#website`, url: siteBaseUrl, name: siteData.meta.title, publisher: { '@id': `${siteBaseUrl}/#org` }, inLanguage: lang }
  - const _graph = [_orgNode, _websiteNode]
  - if (permalink === 'index') {
  -   _graph.push({ '@type': 'MobileApplication', '@id': `${siteBaseUrl}/#app`, name: 'Peach Bitcoin', operatingSystem: ['iOS', 'Android'], applicationCategory: 'FinanceApplication', offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }, downloadUrl: [siteData.meta.iosUrl, siteData.meta.androidUrl].filter(Boolean), publisher: { '@id': `${siteBaseUrl}/#org` } })
  - }
  - if (typeof date !== 'undefined' && date && permalink && permalink.startsWith('blog/') && !_isBlogTag && !_isBlogIndex) {
  -   _graph.push({ '@type': 'BlogPosting', '@id': `${canonicalUrl}#post`, headline: title || derivedTitle, datePublished: date, dateModified: date, image: previewImage ? `${siteBaseUrl}${previewImage}` : undefined, mainEntityOfPage: canonicalUrl, author: { '@id': `${siteBaseUrl}/#org` }, publisher: { '@id': `${siteBaseUrl}/#org` }, inLanguage: lang })
  - }
  - const _jsonLd = JSON.stringify({ '@context': 'https://schema.org', '@graph': _graph })

