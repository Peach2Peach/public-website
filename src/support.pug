extends /template.pug

block append vars
  - const homePath = (lang === 'en' ? '/index.html' : '/' + lang)
  - const hasTeaser = false
  - const hasGuide = (perma) => ((siteData.permalinkLocales && siteData.permalinkLocales[perma]) || ['en']).includes(lang)

