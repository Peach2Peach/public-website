block main
  section.wrap
    .content-wrap.content-wrap--centered
      != html.intro

      .guides(style="display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; padding-bottom: 20px;")
        a.faq-grid-item(href=getUrl("/quick-start/", lang), style="flex: 1;")
          +sprite("mobile")
          h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('mobileQuickStartGuide', lang)}
        a.faq-grid-item(href=getUrl("/web-app-quick-start/", lang), style="flex: 1;")
          +sprite("devices")
          h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('webAppQuickStartGuide', lang)}
        if hasGuide('web-app-settings')
          a.faq-grid-item(href=getUrl("/web-app-settings/", lang), style="flex: 1;")
            +sprite("credit")
            h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('webAppSettingsGuide', lang)}
        if hasGuide('web-app-trading')
          a.faq-grid-item(href=getUrl("/web-app-trading/", lang), style="flex: 1;")
            +sprite("trading")
            h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('webAppTradingGuide', lang)}

      h2 !{i18n('faq', lang)}
      .faq-search
        label.faq-search__label(for="faq-search-input")
          | !{i18n('searchFaq', lang) || 'Search the FAQ'}
        input#faq-search-input.faq-search__input(
          type="search"
          autocomplete="off"
          placeholder=i18n('searchFaqPlaceholder', lang) || 'Type to search questions…'
        )
        .faq-search-results.is-hidden
      .faq.faq-grid
        a.faq-grid-item(href=getUrl("/faq/trading/", lang))
          +sprite("trading")
          h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('trading', lang)}
        a.faq-grid-item(href=getUrl("/faq/matches/", lang))
          +sprite("matches")
          h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('marketplace', lang)}
        a.faq-grid-item(href=getUrl("/faq/escrow-release/", lang))
          +sprite("matches")
          h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('escrowRelease', lang)}
        a.faq-grid-item(href=getUrl("/faq/account/", lang))
          +sprite("account")
          h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('myAccount', lang)}
        a.faq-grid-item(href=getUrl("/faq/pm/", lang))
          +sprite("credit")
          h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('paymentMethods', lang)}
        a.faq-grid-item(href=getUrl("/faq/privacy/", lang))
          +sprite("privacy")
          h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('privacy', lang)}
        a.faq-grid-item(href=getUrl("/faq/tutorials/", lang))
          +sprite("help")
          h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('tutorials', lang)}
        a.faq-grid-item(href=getUrl("/faq/web-app/", lang))
          +sprite("globe")
          h3(style="margin-top: 5px; font-size: 1rem;") !{i18n('webAppFaq', lang)}
          
      != html.contact
      .contact
        a(href=`mailto:${siteData.meta.contactEmail}` title=i18n("email", lang))
          +sprite("social-email", i18n("email", lang))
        include /social.pug

block append scripts
  script.
    window.FAQ_LANG = '#{lang}';
  script(src=assetPath("/js/faq-search.js"))
