extends /template.pug

block append vars
  - const hasTeaser = false

block main
  if title
    h1.sr-only= title
  section.wrap#easy_registration
    article.content-wrap.content-wrap--flex
      div!= html.easy_registration
      figure: img(src=assetPath("/img/how-it-works/easy_registration.png") alt="Easy registration — download the Peach app and start trading without KYC")

  section.wrap#web_app
    article.content-wrap.content-wrap--flex
      div
        h3 !{i18n('home.webApp.title', lang)}
        p !{i18n('home.webApp.subtitle1', lang)}
        p !{i18n('home.webApp.subtitle2', lang)}
        .web-app-cta-row
          a.button.button--primary(href="https://web.peachbitcoin.com" target="_blank" rel="noopener")
            span !{i18n('home.webApp.launchButton', lang)}
            +sprite("external-link")
          a(href=getUrl("/web-app/", lang)) !{i18n('home.webApp.learnMore', lang)}
      figure: img(src=assetPath("/img/web-app/stackingtonUsingPeachWeb.webp") alt=i18n('home.webApp.imageAlt', lang).replace(/&nbsp;/g, ' ') width="954" height="1200" loading="lazy")

  section.wrap#payment
    article.content-wrap.content-wrap--centered
      != html.payment_methods

    article.content-wrap.content-wrap--flex
      div!= html.self_custody
      figure: img(src=assetPath("/img/how-it-works/self_custody.png") alt="Self-custody — your Bitcoin stays in your own wallet throughout the trade")

  section.wrap
    article#sounds_cool.content-wrap.content-wrap--centered
      != html.sounds_cool
      a(href=getUrl("/quick-start/", lang)).button.button--primary
        span !{i18n('quickStartGuide', lang)}
        +sprite("quickstart")

    article.content-wrap.content-wrap--flex
      div!= html.security
      figure: img(src=assetPath("/img/how-it-works/security.png") alt="Security — multisignature escrow protects buyers and sellers")

    article.content-wrap.content-wrap--flex
      div!= html.difference
      figure: img(src=assetPath("/img/how-it-works/difference.png") alt="What makes Peach different — no KYC, non-custodial, peer-to-peer")

  section.wrap
    article#questions.content-wrap.content-wrap--centered
      != html.questions
      a(href=getUrl("/support/", lang)).button.button--primary
        span !{i18n('support', lang)}
        +sprite("help")
