  script.
    document.addEventListener('DOMContentLoaded', () => {
      const featuresContainer = document.querySelector('.features-container');
      const cards = document.querySelectorAll('.features-card');

      function slide() {
        const firstCard = featuresContainer.firstElementChild;
        
        if (featuresContainer.scrollLeft + featuresContainer.clientWidth >= featuresContainer.scrollWidth) {
          featuresContainer.scrollTo({
            left: 0,
            behavior: 'smooth',
          });
        } else {
          featuresContainer.scrollBy({
            left: firstCard.offsetWidth,
            behavior: 'smooth',
          });
        }
      }

      if (window.innerWidth <= 739.99) {
        setInterval(slide, 5000);
      }
    });
    
